FROM python:3.11-slim

# Build-time args
ARG DATABANK_URL=https://github.com/MagnusSletten/Databank
ARG DATABANK_BRANCH=main

# Runtime environment
ENV FLASK_ENV=production \
    DATABANK_PATH=/app/Databank

WORKDIR /app

# 1) Install git & create non-root user
RUN apt-get update \
 && apt-get install -y --no-install-recommends git \
 && rm -rf /var/lib/apt/lists/* \
 && useradd -m -s /bin/bash runner \
 && chown runner:runner /app

# 2) Copy in your portal backend source
COPY --chown=runner:runner src/Backend /app/backend

# 3) As root: install your requirements & clone Databank
USER root
RUN pip install --no-cache-dir -r /app/backend/requirements.txt \
 && git clone --branch "${DATABANK_BRANCH}" --recurse-submodules "${DATABANK_URL}" /app/Databank \
 && pip install --no-cache-dir -e /app/Databank

# 4) Drop to runner for runtime
USER runner
WORKDIR /app/backend

EXPOSE 5001
CMD ["gunicorn", "--config", "gunicorn_config.py", "server:app"]