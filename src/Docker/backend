# Use a slim Python base for smaller image size
FROM python:3.11-slim

# Build args for your Databank and website repos & branches
ARG DATABANK_URL="https://github.com/MagnusSletten/Databank"
ARG DATABANK_BRANCH="main"
ARG WEBSITE_URL="https://github.com/MagnusSletten/nmrlipids-data-portal"
ARG WEBSITE_BRANCH="dev"

# Flask and Databank path environment variables
ENV FLASK_APP=app.py \
    FLASK_ENV=production \
    WEBSITE_URL=${WEBSITE_URL} \
    DATABANK_PATH=/app/Databank

WORKDIR /app
RUN apt-get update \
 && apt-get install -y --no-install-recommends git \
 && rm -rf /var/lib/apt/lists/* \
 && useradd -m -s /bin/bash runner \
 && chown runner:runner /app

# 2) Switch to runner and do all cloning + pip in one layer
USER runner
WORKDIR /app

RUN git clone --branch "${DATABANK_BRANCH}" --recurse-submodules "${DATABANK_URL}" Databank \
 && git clone --branch "${WEBSITE_BRANCH}" "${WEBSITE_URL}" website \
 \
 && pip install --no-cache-dir -r website/src/Backend/requirements.txt \
 && pip install --no-cache-dir -e Databank

# 3) Runtime settings
WORKDIR /app/website
EXPOSE 5001
CMD ["python3", "Backend/src/server.py"]